{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "dot-physical.net" }],
      "destination": "https://www.dot-physical.net/:path*",
      "permanent": true
    },
    { "source": "/order",    "destination": "https://portal.dot-physical.net/order", "permanent": false },
    { "source": "/orders",   "destination": "https://portal.dot-physical.net/order", "permanent": false },
    { "source": "/book.html","destination": "https://portal.dot-physical.net/order", "permanent": false }
  ]
}
